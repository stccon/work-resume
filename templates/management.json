{
  "name": "management",
  "label": "管理岗位",
  "description": "面向团队管理、项目经理等管理岗位的简历模板",
  "sections": [
    {
      "id": "personal",
      "label": "个人信息",
      "fields": [
        { "id": "name", "label": "姓名", "type": "text", "required": true, "order": 1, "prompt": "请问你的姓名是？" },
        { "id": "email", "label": "邮箱", "type": "text", "required": true, "order": 2, "prompt": "你的邮箱地址是？" },
        { "id": "phone", "label": "电话", "type": "text", "required": true, "order": 3, "prompt": "你的手机号码是？" },
        { "id": "title", "label": "求职意向", "type": "text", "required": true, "order": 4, "prompt": "你想应聘什么管理岗位？" }
      ]
    },
    {
      "id": "summary",
      "label": "管理经验概述",
      "fields": [
        { "id": "summary", "label": "概述", "type": "textarea", "required": true, "order": 1, "prompt": "请概述你的管理经验和领导风格", "followUpPrompt": "能具体说说你管理过的团队规模和类型吗？" }
      ]
    },
    {
      "id": "experience",
      "label": "工作经历",
      "fields": [
        { "id": "company", "label": "公司", "type": "text", "required": true, "order": 1, "prompt": "最近在哪家公司担任管理职务？" },
        { "id": "position", "label": "职位", "type": "text", "required": true, "order": 2, "prompt": "你的管理职位是什么？" },
        { "id": "teamSize", "label": "团队规模", "type": "text", "required": true, "order": 3, "prompt": "你管理多大的团队？" },
        { "id": "startDate", "label": "开始时间", "type": "date", "required": true, "order": 4, "prompt": "什么时候开始的？" },
        { "id": "endDate", "label": "结束时间", "type": "date", "required": false, "order": 5, "prompt": "什么时候结束的？" },
        { "id": "responsibilities", "label": "管理职责", "type": "textarea", "required": true, "order": 6, "prompt": "你的主要管理职责是什么？", "followUpPrompt": "还有哪些管理方面的成就？" },
        { "id": "achievements", "label": "管理成果", "type": "textarea", "required": true, "order": 7, "prompt": "在管理岗位上取得了哪些关键成果？比如效率提升、团队成长等" }
      ]
    },
    {
      "id": "education",
      "label": "教育背景",
      "fields": [
        { "id": "school", "label": "学校", "type": "text", "required": true, "order": 1, "prompt": "你的教育背景是？" },
        { "id": "major", "label": "专业", "type": "text", "required": true, "order": 2, "prompt": "学的什么专业？" },
        { "id": "degree", "label": "学位", "type": "text", "required": true, "order": 3, "prompt": "什么学位？" },
        { "id": "gradYear", "label": "毕业年份", "type": "date", "required": true, "order": 4, "prompt": "哪年毕业？" }
      ]
    },
    {
      "id": "certifications",
      "label": "证书与培训",
      "fields": [
        { "id": "certifications", "label": "证书", "type": "textarea", "required": false, "order": 1, "prompt": "有哪些管理相关的证书或培训经历？" }
      ]
    }
  ]
}
