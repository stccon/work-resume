{
  "name": "technical",
  "label": "技术岗位",
  "description": "面向程序员、工程师等技术岗位的简历模板",
  "sections": [
    {
      "id": "personal",
      "label": "个人信息",
      "fields": [
        { "id": "name", "label": "姓名", "type": "text", "required": true, "order": 1, "prompt": "请问你的姓名是？" },
        { "id": "email", "label": "邮箱", "type": "text", "required": true, "order": 2, "prompt": "你的邮箱地址是？" },
        { "id": "phone", "label": "电话", "type": "text", "required": true, "order": 3, "prompt": "你的手机号码是？" },
        { "id": "github", "label": "GitHub/作品链接", "type": "text", "required": false, "order": 4, "prompt": "有 GitHub 或作品链接吗？" },
        { "id": "title", "label": "求职意向", "type": "text", "required": true, "order": 5, "prompt": "你想应聘什么技术岗位？" }
      ]
    },
    {
      "id": "summary",
      "label": "技术简介",
      "fields": [
        { "id": "summary", "label": "简介", "type": "textarea", "required": true, "order": 1, "prompt": "请简要介绍你的技术背景和核心优势", "followUpPrompt": "能详细说说你的技术专长吗？" }
      ]
    },
    {
      "id": "skills",
      "label": "技术栈",
      "fields": [
        { "id": "languages", "label": "编程语言", "type": "text", "required": true, "order": 1, "prompt": "你会哪些编程语言？" },
        { "id": "frameworks", "label": "框架/工具", "type": "text", "required": false, "order": 2, "prompt": "用过哪些框架或工具？" },
        { "id": "databases", "label": "数据库", "type": "text", "required": false, "order": 3, "prompt": "熟悉哪些数据库？" },
        { "id": "cloud", "label": "云服务", "type": "text", "required": false, "order": 4, "prompt": "有云服务经验吗？比如 AWS、阿里云等" }
      ]
    },
    {
      "id": "experience",
      "label": "工作经历",
      "fields": [
        { "id": "company", "label": "公司", "type": "text", "required": true, "order": 1, "prompt": "最近在哪家公司做技术？" },
        { "id": "position", "label": "职位", "type": "text", "required": true, "order": 2, "prompt": "你的技术职位是什么？" },
        { "id": "startDate", "label": "开始时间", "type": "date", "required": true, "order": 3, "prompt": "什么时候开始的？" },
        { "id": "endDate", "label": "结束时间", "type": "date", "required": false, "order": 4, "prompt": "什么时候结束的？" },
        { "id": "techStack", "label": "技术栈", "type": "text", "required": true, "order": 5, "prompt": "在那里用了什么技术栈？" },
        { "id": "projects", "label": "项目经验", "type": "textarea", "required": true, "order": 6, "prompt": "做过哪些项目？你在其中的角色和贡献是什么？", "followUpPrompt": "有没有什么技术难点是你解决的？" }
      ]
    },
    {
      "id": "education",
      "label": "教育背景",
      "fields": [
        { "id": "school", "label": "学校", "type": "text", "required": true, "order": 1, "prompt": "你的教育背景是？" },
        { "id": "major", "label": "专业", "type": "text", "required": true, "order": 2, "prompt": "学的什么专业？" },
        { "id": "degree", "label": "学位", "type": "text", "required": true, "order": 3, "prompt": "什么学位？" },
        { "id": "gradYear", "label": "毕业年份", "type": "date", "required": true, "order": 4, "prompt": "哪年毕业？" }
      ]
    }
  ]
}
