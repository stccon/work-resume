{
  "name": "general",
  "label": "通用简历",
  "description": "适合所有求职场景的简历模板，AI 根据对话自动填充相关字段",
  "sections": [
    {
      "id": "personal",
      "label": "个人信息",
      "fields": [
        { "id": "name", "label": "姓名", "type": "text", "required": true, "order": 1, "prompt": "请问你的姓名是？" },
        { "id": "email", "label": "邮箱", "type": "text", "required": true, "order": 2, "prompt": "你的邮箱地址是？" },
        { "id": "phone", "label": "电话", "type": "text", "required": true, "order": 3, "prompt": "你的手机号码是？" },
        { "id": "title", "label": "求职意向", "type": "text", "required": true, "order": 4, "prompt": "你想应聘什么职位？" },
        { "id": "github", "label": "GitHub/作品链接", "type": "text", "required": false, "order": 5, "prompt": "有 GitHub 或作品链接吗？" }
      ]
    },
    {
      "id": "summary",
      "label": "个人简介",
      "fields": [
        { "id": "summary", "label": "简介", "type": "textarea", "required": true, "order": 1, "prompt": "请介绍一下你自己，包括工作经验和核心优势", "followUpPrompt": "能再详细说说你的专业背景吗？" }
      ]
    },
    {
      "id": "skills",
      "label": "技能",
      "fields": [
        { "id": "skills", "label": "技能概述", "type": "skills", "required": true, "order": 1, "prompt": "你掌握哪些技能？比如编程语言、工具、软技能等", "followUpPrompt": "还有别的技能吗？" },
        { "id": "languages", "label": "编程语言", "type": "text", "required": false, "order": 2, "prompt": "你会哪些编程语言？" },
        { "id": "frameworks", "label": "框架/工具", "type": "text", "required": false, "order": 3, "prompt": "用过哪些框架或工具？" },
        { "id": "databases", "label": "数据库", "type": "text", "required": false, "order": 4, "prompt": "熟悉哪些数据库？" },
        { "id": "cloud", "label": "云服务", "type": "text", "required": false, "order": 5, "prompt": "有云服务经验吗？比如 AWS、阿里云等" }
      ]
    },
    {
      "id": "experience",
      "label": "工作经历",
      "fields": [
        { "id": "company", "label": "公司名称", "type": "text", "required": true, "order": 1, "prompt": "你最近在哪家公司工作？" },
        { "id": "position", "label": "职位", "type": "text", "required": true, "order": 2, "prompt": "你的职位是什么？" },
        { "id": "startDate", "label": "开始时间", "type": "date", "required": true, "order": 3, "prompt": "什么时候开始的？" },
        { "id": "endDate", "label": "结束时间", "type": "date", "required": false, "order": 4, "prompt": "什么时候结束的？（如果还在职可以跳过）" },
        { "id": "achievements", "label": "工作成就", "type": "textarea", "required": true, "order": 5, "prompt": "在这家公司你取得了哪些成就？", "followUpPrompt": "还有其他的成就或项目经验吗？" },
        { "id": "techStack", "label": "技术栈", "type": "text", "required": false, "order": 6, "prompt": "在那里用了什么技术栈？" },
        { "id": "projects", "label": "项目经验", "type": "textarea", "required": false, "order": 7, "prompt": "做过哪些项目？你在其中的角色和贡献是什么？" },
        { "id": "teamSize", "label": "团队规模", "type": "text", "required": false, "order": 8, "prompt": "你管理多大的团队？" },
        { "id": "responsibilities", "label": "管理职责", "type": "textarea", "required": false, "order": 9, "prompt": "你的主要管理职责是什么？" }
      ]
    },
    {
      "id": "education",
      "label": "教育背景",
      "fields": [
        { "id": "school", "label": "学校", "type": "text", "required": true, "order": 1, "prompt": "你的最高学历是什么？哪个学校？" },
        { "id": "major", "label": "专业", "type": "text", "required": true, "order": 2, "prompt": "你学的什么专业？" },
        { "id": "degree", "label": "学位", "type": "text", "required": true, "order": 3, "prompt": "是什么学位？" },
        { "id": "gradYear", "label": "毕业年份", "type": "date", "required": true, "order": 4, "prompt": "哪年毕业的？" }
      ]
    },
    {
      "id": "certifications",
      "label": "证书与培训",
      "fields": [
        { "id": "certifications", "label": "证书", "type": "textarea", "required": false, "order": 1, "prompt": "有哪些相关的证书或培训经历？" }
      ]
    }
  ]
}
