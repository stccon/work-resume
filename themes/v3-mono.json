{
  "name": "v3-mono",
  "label": "Mono",
  "description": "等宽字体工程师风格简历。全部 mono 字符 + tabular-nums + // 分隔符。适合技术简历、终端/SRE/编译岗",
  "hasAvatar": false,
  "typeFamily": "mono",
  "sectionOrder": [
    "personal",
    "summary",
    "skills",
    "experience",
    "projects",
    "education",
    "awards",
    "certifications"
  ],
  "fonts": {
    "heading": "ui-monospace, 'JetBrains Mono', 'SF Mono', 'Cascadia Code', Consolas, 'Liberation Mono', 'Courier New', monospace",
    "body": "ui-monospace, 'JetBrains Mono', 'SF Mono', 'Cascadia Code', Consolas, 'Liberation Mono', 'Courier New', monospace",
    "mono": "ui-monospace, 'JetBrains Mono', 'SF Mono', 'Cascadia Code', Consolas, 'Liberation Mono', 'Courier New', monospace"
  },
  "typography": {
    "name": {
      "size": "24px",
      "weight": 700,
      "lineHeight": "32px"
    },
    "title": {
      "size": "13px",
      "weight": 500,
      "lineHeight": "20px"
    },
    "sectionTitle": {
      "size": "12px",
      "weight": 700,
      "lineHeight": "16px",
      "letterSpacing": "0.05em"
    },
    "body": {
      "size": "11px",
      "weight": 400,
      "lineHeight": "16px"
    },
    "entryTitle": {
      "size": "12px",
      "weight": 600,
      "lineHeight": "16px"
    },
    "entryDate": {
      "size": "11px",
      "weight": 400,
      "lineHeight": "16px",
      "tabularNums": true
    }
  },
  "colors": {
    "primary": "#0a0a0a",
    "accent": "#0a0a0a",
    "background": "#ffffff",
    "surface": "#fafafa",
    "border": "#d4d4d4",
    "muted": "#737373",
    "text": "#0a0a0a"
  },
  "baseline": 4,
  "spacing": {
    "pagePadding": "48px",
    "sectionGap": "24px",
    "entryGap": "12px"
  },
  "density": "dense",
  "sectionTitleRule": "short-line",
  "sectionTitleRuleWidth": "32px",
  "sectionTitleRuleHeight": "1px",
  "sectionTitleRuleOffset": "8px",
  "bullet": "›",
  "bulletColor": "muted",
  "tagStyle": "underline",
  "print": {
    "pageBreakInsideEntry": true,
    "pageBreakInsideSection": true,
    "tabularNums": true,
    "hanLatinSpacing": "0.05em"
  }
