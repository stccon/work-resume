  "colors": {
    "primary": "#2a2520",
    "primaryLight": "#f4f1ec",
    "text": "#1f1b16",
    "textMuted": "#6b6259",
    "background": "#fefdf9",
    "border": "#d6cfc3",
    "divider": "#2a2520",
    "accent": "#5c4a2f"
  },
  "fonts": {
    "heading": "'Alegreya', 'Source Han Serif SC', 'Noto Serif SC', 'Songti SC', Georgia, 'Times New Roman', serif",
    "body": "'Source Han Serif SC', 'Noto Serif SC', 'Songti SC', Georgia, 'Times New Roman', serif",
    "mono": "ui-monospace, 'SF Mono', Menlo, Consolas, monospace"
  },
  "typography": {
