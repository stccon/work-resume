{
  "name": "v2-academic-serif",
  "label": "学术典雅 Serif",
  "description": "衬线大姓名+罗马数字章节+boxed 标题，Overleaf/Pro Academic CV 学术风，适合教授/博士/科研机构",
  "series": "v2",
  "family": "editorial",
  "language": "auto",
  "layout": "single-column",
  "headerStyle": "left",
