    "sectionTitleLetterSpacing": "0.1em"
  },
  "sectionStyle": "minimal",
  "spacing": {
    "pagePadding": "48px",
    "sectionGap": "22px",
    "entryGap": "12px"
  },
  "borderRadius": "0",
