    "headerVariant": "split",
    "sectionTitleRule": "short-line",
    "contactSeparator": "  /  ",
    "showHeaderDivider": false,
    "nameStyle": "default",
    "bulletStyle": "arrow",
    "tagStyle": "pill",
    "avatar": {
      "defaultEnabled": false,
      "placement": "top-left",
      "size": "small",
      "shape": "circle",
      "border": "thin"
