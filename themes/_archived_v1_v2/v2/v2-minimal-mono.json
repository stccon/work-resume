{
  "name": "v2-minimal-mono",
  "label": "极简主义 Mono",
  "description": "纯黑灰阶+极致留白，Atlassian/Linear 工程师风格，适合互联网/产品/技术岗",
  "series": "v2",
  "family": "minimal",
  "language": "auto",
  "layout": "single-column",
  "headerStyle": "left",
  "decorationStyle": "none",
  "colors": {
    "primary": "#0a0a0a",
    "primaryLight": "#f5f5f5",
    "text": "#0a0a0a",
    "textMuted": "#737373",
    "background": "#ffffff",
    "border": "#e5e5e5",
    "divider": "#0a0a0a",
    "accent": "#0a0a0a"
  },
  "fonts": {
    "heading": "-apple-system, 'SF Pro Display', 'PingFang SC', 'Microsoft YaHei', 'Noto Sans SC', sans-serif",
    "body": "-apple-system, 'SF Pro Text', 'PingFang SC', 'Microsoft YaHei', 'Noto Sans SC', sans-serif",
    "mono": "ui-monospace, 'SF Mono', 'JetBrains Mono', Menlo, Consolas, monospace"
  },
  "typography": {
    "nameFontSize": "28px",
    "titleFontSize": "13px",
    "sectionTitleFontSize": "11px",
    "bodyFontSize": "11px",
    "lineHeight": "1.55",
    "nameLetterSpacing": "-0.02em",
    "sectionTitleTransform": "uppercase",
    "sectionTitleLetterSpacing": "0.18em"
  },
  "sectionStyle": "minimal",
  "spacing": {
    "pagePadding": "56px",
    "sectionGap": "28px",
    "entryGap": "14px"
  },
  "borderRadius": "0",
  "v2Config": {
    "headerVariant": "minimal",
    "sectionTitleRule": "short-line",
    "contactSeparator": "  /  ",
    "showHeaderDivider": true,
    "nameStyle": "default",
    "bulletStyle": "square",
    "tagStyle": "flat",
    "avatar": {
      "defaultEnabled": false,
      "placement": "top-right",
      "size": "small",
      "shape": "circle",
      "border": "thin"
    }
  }
}
