{
  "name": "v2-editorial",
  "label": "编辑式 Editorial",
  "description": "衬线大标题+极简正文+大量留白，杂志风格，适合设计/品牌/媒体/教育/文化行业",
  "series": "v2",
  "family": "editorial",
  "language": "auto",
  "layout": "single-column",
  "headerStyle": "left",
  "decorationStyle": "none",
  "colors": {
    "primary": "#1a1a1a",
    "primaryLight": "#faf8f5",
    "text": "#1a1a1a",
    "textMuted": "#6b6b6b",
    "background": "#fefdfb",
    "border": "#e8e4dc",
    "divider": "#1a1a1a",
    "accent": "#a85432",
    "sectionBg": "#f7f3ec"
  },
  "fonts": {
    "heading": "'Playfair Display', 'Source Han Serif SC', 'Noto Serif SC', 'Songti SC', Georgia, serif",
    "body": "'Inter', -apple-system, 'PingFang SC', 'Microsoft YaHei', 'Noto Sans SC', sans-serif",
    "mono": "ui-monospace, 'SF Mono', Menlo, Consolas, monospace"
  },
  "typography": {
    "nameFontSize": "42px",
    "titleFontSize": "14px",
    "sectionTitleFontSize": "12px",
    "bodyFontSize": "11.5px",
    "lineHeight": "1.7",
    "nameLetterSpacing": "-0.025em",
    "sectionTitleTransform": "uppercase",
    "sectionTitleLetterSpacing": "0.22em"
  },
  "sectionStyle": "minimal",
  "spacing": {
    "pagePadding": "64px",
    "sectionGap": "32px",
    "entryGap": "18px"
  },
  "borderRadius": "0",
  "v2Config": {
    "headerVariant": "magazine",
    "sectionTitleRule": "full-line",
    "contactSeparator": "  ·  ",
    "showHeaderDivider": false,
    "nameStyle": "serif-large",
    "bulletStyle": "arrow",
    "tagStyle": "underline",
    "avatar": {
      "defaultEnabled": true,
      "placement": "top-right",
      "size": "medium",
      "shape": "rounded",
      "border": "thin"
    }
  }
}
