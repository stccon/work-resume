{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "composite": true,
    "declaration": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["vite.config.ts", "electron"]
}
